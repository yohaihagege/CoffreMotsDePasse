sel = b'mon_sel_unique_et_constant'
cle = generer_cle_depuis_mdp(mot_de_passe_maitre, sel)

# ---------- Mot de passe secondaire ----------
mdp_secondaire = charger_mdp_secondaire()
if not mdp_secondaire:
    nouveau_mdp = simpledialog.askstring("Mot de passe secondaire 🔐", "Définir un mot de passe secondaire :", show='*')
    if not nouveau_mdp:
        messagebox.showerror("Erreur", "Mot de passe secondaire requis. Fermeture.")
        app.destroy()
        exit()
    sauvegarder_mdp_secondaire(nouveau_mdp)
    mdp_secondaire = nouveau_mdp

devoile_mdp = False

# ---------- Fonctions ----------
def ajouter_mot_de_passe():
    fenetre = tk.Toplevel(app)
    fenetre.title("Ajouter un mot de passe")
    fenetre.geometry("400x300")
    fenetre.grab_set()
    fenetre.configure(bg="#1e272e")

    def style_label(widget, text):
        tk.Label(widget, text=text, font=("Segoe UI", 11), bg="#1e272e", fg="white").pack(pady=5)

    style_label(fenetre, "Site :")
    entree_site = ttk.Entry(fenetre, width=40)
    entree_site.pack()

    style_label(fenetre, "Identifiant :")
    entree_identifiant = ttk.Entry(fenetre, width=40)
    entree_identifiant.pack()

    def generer_dans_champ():
        longueur = 16
        caracteres = string.ascii_letters + string.digits + string.punctuation
        while True:
            mdp = ''.join(random.choice(caracteres) for _ in range(longueur))
            if (
                any(c.isdigit() for c in mdp)
                and any(c in string.punctuation for c in mdp)
                and len(mdp) >= 12
            ):
                break
        champ_mdp.delete(0, tk.END)
        champ_mdp.insert(0, mdp)
        app.clipboard_clear()
        app.clipboard_append(mdp)
        app.update()
        messagebox.showinfo("Mot de passe généré", f"Mot de passe copié dans le presse-papiers.")

    ttk.Button(fenetre, text="🔐 Générer un mot de passe", command=generer_dans_champ).pack(pady=5)

    style_label(fenetre, "Mot de passe :")
    champ_mdp = ttk.Entry(fenetre, width=40, show='*')
    champ_mdp.pack()

    def valider():
        site = entree_site.get().strip()
        identifiant = entree_identifiant.get().strip()
        mdp = champ_mdp.get().strip()

        if not site or not identifiant or not mdp:
            messagebox.showerror("Erreur", "Tous les champs sont obligatoires.")
            return

        if len(mdp) < 12 or not any(c.isdigit() for c in mdp) or not any(c in string.punctuation for c in mdp):
            messagebox.showerror("Erreur", "Le mot de passe doit contenir au moins 12 caractères,\n1 chiffre et 1 caractère spécial.")
            return

        data = charger_donnees()
        donnees_chiffrees = chiffrer(cle, f"{identifiant}:{mdp}")
        data[site] = donnees_chiffrees.decode()
        sauvegarder_donnees(data)
        rafraichir_tableau()
        recherche_var.set("")
        fenetre.destroy()

    ttk.Button(fenetre, text="✅ Enregistrer", command=valider).pack(pady=15)

def modifier_mot_de_passe():
    item = tableau.selection()
    if item:
        site = tableau.item(item)['values'][0]
        identifiant = simpledialog.askstring("Modifier", "Nouvel identifiant :", initialvalue=tableau.item(item)['values'][1])
        mdp = simpledialog.askstring("Modifier", "Nouveau mot de passe :", initialvalue=tableau.item(item)['values'][2])
        if identifiant and mdp:
            data = charger_donnees()
            data[site] = chiffrer(cle, f"{identifiant}:{mdp}").decode()
            sauvegarder_donnees(data)
            rafraichir_tableau()
    else:
        messagebox.showerror("Erreur", "Sélectionnez un site à modifier.")

def supprimer_mot_de_passe():
    item = tableau.selection()
    if item:
        site = tableau.item(item)['values'][0]
        confirmation = messagebox.askyesno("Supprimer", f"Supprimer les données pour {site} ?")
        if confirmation:
            data = charger_donnees()
            del data[site]
            sauvegarder_donnees(data)
            rafraichir_tableau()
    else:
        messagebox.showerror("Erreur", "Sélectionnez un site à supprimer.")

def rafraichir_tableau():
    for row in tableau.get_children():
        tableau.delete(row)
    data = charger_donnees()
    for site, donnees_chiffrees in data.items():
        try:
            identifiant, mot_de_passe = dechiffrer(cle, donnees_chiffrees.encode()).split(":")
            affichage_mdp = mot_de_passe if devoile_mdp else "********"
            tableau.insert("", "end", values=(site, identifiant, affichage_mdp))
        except:
            continue

def afficher_apres_deverrouillage(event):
    global devoile_mdp
    if devoile_mdp:
        return
    tentative = simpledialog.askstring("🔒 Sécurité", "Entrez le mot de passe secondaire :", show='*')
    if tentative == mdp_secondaire:
        devoile_mdp = True
        rafraichir_tableau()
    else:
        messagebox.showerror("Erreur", "Mot de passe incorrect.")

def recherche_sites(event=None):
    filtre = recherche_var.get().lower()
    for row in tableau.get_children():
        tableau.delete(row)
    data = charger_donnees()
    for site, donnees_chiffrees in data.items():
        try:
            identifiant, mot_de_passe = dechiffrer(cle, donnees_chiffrees.encode()).split(":")
            if filtre in site.lower():
                affichage_mdp = mot_de_passe if devoile_mdp else "********"
                tableau.insert("", "end", values=(site, identifiant, affichage_mdp))
        except:
            continue

